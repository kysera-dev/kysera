    "@kysera/infra": "workspace:*",
    "@kysera/debug": "workspace:*",
    "kysely": "^0.28.12",
    "pg": "^8.20.0",
    "zod": "^4.3.6",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
