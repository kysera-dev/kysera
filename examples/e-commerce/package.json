{
  "name": "e-commerce-example",
  "version": "0.8.6",
  "private": true,
  "type": "module",
  "description": "E-commerce application example using Kysera",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
